# ─────────────────────────────────────────────────────────────────────────────
# scripts/deploy-aws.{sh,ps1} — copy this to scripts/.env.deploy and fill in.
# Anything left unset that the script needs will fail loudly at start.
# ─────────────────────────────────────────────────────────────────────────────

# --- AWS target host (EC2, spot or on-demand) --------------------------------
AWS_HOST=ec2-XX-XX-XX-XX.compute.amazonaws.com
AWS_USER=ubuntu
# Path to the SSH private key (.pem) used to reach the instance. Use $HOME or
# ~ — the deploy script will expand it. Avoid hard-coded user-specific roots.
AWS_SSH_KEY=$HOME/.ssh/neoterritory.pem
# Remote port the container should publish on the host. Default 80.
AWS_HOST_PORT=80
# Remote working dir for --source mode (where the tarball is extracted and
# the docker build runs). Default: /home/$AWS_USER/neoterritory
# REMOTE_APP_DIR=/home/ubuntu/neoterritory

# Lightsail public firewall — set BOTH to auto-open the port via the AWS
# CLI on every deploy (otherwise you must open it manually in the Lightsail
# console → Instance → Networking → IPv4 Firewall). Requires `aws configure`
# to have been run with credentials that can call lightsail:*.
# AWS_LIGHTSAIL_INSTANCE_NAME=Ubuntu-1
# AWS_LIGHTSAIL_REGION=ap-southeast-1

# Public origin the browser will hit (used for backend CORS). If unset,
# the deploy script defaults to http://$AWS_HOST(:port). Override once
# you put a custom domain or TLS in front:
# CORS_ORIGIN=https://neoterritory.example.com

# --- Image / container -------------------------------------------------------
IMAGE_NAME=neoterritory
IMAGE_TAG=latest
CONTAINER_NAME=neoterritory

# --- Supabase (used as default DB sink for AWS deployments) -----------------
# Get these from Supabase project → Settings → API.
# SUPABASE_SERVICE_KEY is the SERVICE-ROLE key (server-side only — never ship
# this to the frontend). Leave both blank to disable Supabase mirroring even
# in AWS mode (the container will run with local SQLite only).
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...service-role-key...
# Override only if you renamed the tables in supabase_admin_logs.sql.
SUPABASE_LOGS_TABLE=admin_logs
SUPABASE_AUDIT_TABLE=admin_audit_log

# --- Google sign-in (Supabase cloud) ----------------------------------------
# Set AUTH_PROVIDER=supabase_cloud to route /auth/google/* through the
# project at SUPABASE_URL above. ANON_KEY = "anon public" key from
# Supabase dashboard → Settings → API. The Google OAuth client ID/secret
# are downloaded from console.cloud.google.com → Credentials.
# Leave AUTH_PROVIDER unset (or set to "dev") to keep the devcon-only flow.
# AUTH_PROVIDER=supabase_cloud
# AUTH_SUPABASE_ANON_KEY=eyJhbGciOi...anon-key...
# GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://xxxxxxxx.supabase.co/auth/v1/callback

# --- Backend secrets passed through to the remote container -----------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# AI provider — pick ONE. Backend auto-detects (Gemini wins if both set).
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# ANTHROPIC_API_KEY=

ADMIN_USERNAME=Neoterritory
ADMIN_PASSWORD=

# --- Per-user C++ test-runner pods ------------------------------------------
# Pod-per-online-user microservice. When TEST_RUNNER_USE_DOCKER=1 the backend
# spawns a long-lived `neoterritory/cpp-pod` container per signed-in user
# (services/podManager.ts) and routes /api/runs compiles + executions into
# that pod. The container image is built once on first boot from
# Codebase/Backend/docker/cpp-pod.Dockerfile.
TEST_RUNNER_USE_DOCKER=1

# /api/runs endpoint gate. Production refuses to enable the runner unless
# BOTH are set (services/testRunnerService.ts:isTestRunnerEnabled). The
# sandbox value is the local-fallback wrapper used when a user's pod is
# still warming up — `firejail` is installed by scripts/lightsail-launch.sh.
ENABLE_TEST_RUNNER=1
TEST_RUNNER_SANDBOX="firejail --quiet --net=none --noprofile --rlimit-as=268435456"
