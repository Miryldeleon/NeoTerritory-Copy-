# Server
PORT=3001
SSL_PORT=443
CORS_ORIGIN=http://localhost:3001

# SSL Certificates (Optional for direct HTTPS support)
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem

# Database (optional — defaults to Codebase/Backend/neoterritory.db)
# DB_PATH=/absolute/path/to/neoterritory.db

# Supabase admin/audit log mirror (optional locally, default-on for AWS).
# When BOTH are set, every logEvent + logAudit also POSTs to Supabase via
# PostgREST. SQLite stays the source of truth so a downed AWS spot instance
# never costs you the data. Leave blank for local-only operation.
# Run Codebase/Backend/sql/supabase_admin_logs.sql once in the Supabase
# SQL editor to provision the mirror tables.
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_KEY=
# SUPABASE_LOGS_TABLE=admin_logs
# SUPABASE_AUDIT_TABLE=admin_audit_log

# ────────────────────────────────────────────────────────────────────
# Account creation — feature-flagged auth. The default is "dev" which
# keeps the existing Devcon test-account flow. Set AUTH_PROVIDER to
# enable real account creation when the team is ready.
#
#   AUTH_PROVIDER=dev                   # devcon test accounts (default)
#   AUTH_PROVIDER=supabase_self_hosted  # local self-hosted Supabase
#                                       # (run scripts/setup-supabase.sh)
#   AUTH_PROVIDER=supabase_cloud        # supabase.com hosted project
#
# When self-hosted is selected and the local Supabase is unreachable
# the backend falls back to supabase_cloud automatically (if its keys
# are set), then to dev as a final fallback. See scripts/setup-supabase.sh
# and docs/AUTH_SETUP.md.
# AUTH_PROVIDER=dev
# AUTH_SUPABASE_ANON_KEY=
# AUTH_SUPABASE_GOOGLE_REDIRECT_URL=http://localhost:3001/auth/google/callback
# Self-hosted only — local Supabase URL printed by `supabase start`.
# AUTH_SUPABASE_SELF_HOSTED_URL=http://127.0.0.1:54321

# Auth — long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# If left unset or empty the backend autogenerates a one-shot secret on startup
# (with a warning) so first-clone developers don't hit "secretOrPrivateKey must
# have a value". Sessions then invalidate every restart. Always set explicitly
# in production.
JWT_SECRET=

# AI Documentation — choose one provider. If both keys are set, GEMINI wins
# unless AI_PROVIDER=anthropic is also set.
# AI_PROVIDER=gemini

# Google Gemini (AI Studio): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (alternative): https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# C++ Pattern Microservice
NEOTERRITORY_BIN=/path/to/NeoTerritory/binary
NEOTERRITORY_CATALOG=/path/to/pattern_catalog.json

# Test output directory (optional — defaults to repo root /test)
# TEST_RESULTS_DIR=/absolute/path/to/test

# Per-user file cap on /analyze submissions. Default 3 (raise carefully —
# microservice envelope is tested up to 16; values above 16 are clamped).
MAX_FILES_PER_SUBMISSION=3

# GDB Runner sandbox + rate limit. The Docker runtime image bakes in
# ENABLE_TEST_RUNNER=1, TEST_RUNNER_USE_DOCKER=1, and a firejail
# TEST_RUNNER_SANDBOX as the production default — pod mode (sibling
# Docker containers via mounted /var/run/docker.sock) is preferred and
# falls back to the local firejail sandbox. Override here only to turn
# the runner OFF or to swap sandbox commands for local dev.
# ENABLE_TEST_RUNNER=1
# TEST_RUNNER_USE_DOCKER=1
# POD_WARMUP_ON_CLAIM=1
# TEST_RUNNER_SANDBOX="firejail --quiet --net=none --noprofile --rlimit-as=268435456"
GDB_RUNS_PER_WINDOW=5
GDB_COOLDOWN_MS=60000

# Web scraper (D35) — DEFERRED, admin-only, off by default. When set to "1"
# mounts /api/admin/scraper/{start,stop,status} and lets the bundled
# tools/scraper/run.mjs spawn a headed Playwright Chromium for manual-login
# data collection. Off in production. Only flip on for local research use.
# NEOTERRITORY_ENABLE_SCRAPER=0

# Seeds — TEST ONLY
# Set SEED_TEST_USERS=1 to seed 100 Devcon test accounts (Devcon1..Devcon100, password "devcon").
# Default when unset or any value other than "1": NO test users are seeded.
# MUST be unset (or removed entirely) in production.
# SEED_TEST_USERS=1
# SEED_ADMIN_PASSWORD=change_me
