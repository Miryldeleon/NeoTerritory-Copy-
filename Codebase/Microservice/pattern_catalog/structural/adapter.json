{
  "pattern_id": "structural.adapter",
  "pattern_family": "structural",
  "pattern_name": "Adapter",
  "enabled": true,
  "signature_categories": [],
  "negative_signature_categories": [
    "ownership_handle",
    "interface_polymorphism",
    "access_control_caching"
  ],
  "lexeme_identifiers": {
    "forwarding":           ["->", "."],
    "wrapped_member":       ["target", "wrappee", "adaptee", "adaptee_", "impl_",
                             "m_adaptee", "m_target", "wrapped_", "target_",
                             "delegate_", "inner_", "m_inner"],
    "functional_adapter":   ["std::function", "function", "std::bind", "bind",
                             "std::mem_fn", "mem_fn", "std::invoke", "invoke",
                             "std::ref", "ref", "std::cref",
                             "std::placeholders", "placeholders",
                             "_1", "_2", "_3"],
    "interface_methods":    ["adapt", "convert", "translate", "wrap", "transform",
                             "process", "handle", "execute", "request", "perform",
                             "delegate", "forward", "relay"],
    "virtual_interface":    ["virtual", "override", "final"],
    "ownership_types":      ["unique_ptr", "shared_ptr", "std::unique_ptr",
                             "std::shared_ptr", "make_unique", "make_shared"]
  },
  "ordered_checks": [
    {
      "id": "class_introducer",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["class", "struct"]
    },
    {
      "id": "class_name",
      "expected_kind": "Identifier",
      "capture_as": "class_name",
      "document_as": "adapter_class"
    },
    {
      "id": "open_class_brace",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["{"]
    },
    {
      "id": "wrapped_member",
      "expected_kind": "Identifier",
      "capture_as": "wrapped_member",
      "document_as": "adapter_wrapped_target"
    },
    {
      "id": "forward_operator",
      "one_of": [
        { "expected_kind": "Punctuation", "expected_lexeme_any_of": ["."] },
        { "expected_kind": "Operator",    "expected_lexeme_any_of": ["->"] }
      ],
      "document_as": "adapter_forwarding_op"
    },
    {
      "id": "forwarded_method",
      "expected_kind": "Identifier",
      "capture_as": "forwarded_method",
      "document_as": "adapter_forwarded_call"
    },
    {
      "id": "forwarded_open_paren",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["("]
    }
  ],

  "implementation_template": {
    "callsites": [
      {
        "id": "wrapper_method_usage",
        "shape_regex": "\\b{class_name}\\s+\\w+\\s*\\([^)]*\\)\\s*;[\\s\\S]{0,200}\\w+\\s*\\.\\s*\\w+\\s*\\(",
        "weight": 0.55,
        "describe": "Adapter is constructed then has a method called on it"
      },
      {
        "id": "adaptee_pointer_member",
        "shape_regex": "\\b\\w+\\s*\\*\\s*(adaptee_?|target_?|wrappee_?|wrapped_?|m_inner|inner_?|delegate_?|m_adaptee|m_target)\\s*;",
        "weight": 0.5,
        "describe": "Adapter holds a raw pointer to the adaptee/wrapped object"
      },
      {
        "id": "adaptee_smart_member",
        "shape_regex": "(std::)?(unique_ptr|shared_ptr)\\s*<[^>]+>\\s*(adaptee_?|target_?|wrappee_?|wrapped_?|m_inner|inner_?|delegate_?|m_adaptee|m_target)\\s*;",
        "weight": 0.55,
        "describe": "Adapter owns the adaptee via smart pointer"
      },
      {
        "id": "ctor_inject_adaptee",
        "shape_regex": "{class_name}\\s*\\([^)]*\\)\\s*:[^{]*\\b(adaptee_?|target_?|wrappee_?|m_inner|inner_?|delegate_?|m_target)\\s*\\(",
        "weight": 0.45,
        "describe": "Constructor initializer captures the adaptee"
      },
      {
        "id": "in_body_translation_call",
        "shape_regex": "\\b(adaptee_?|target_?|wrappee_?|m_inner|inner_?|delegate_?|m_target)\\s*->\\s*\\w+\\s*\\(",
        "weight": 0.45,
        "describe": "Adapter method body forwards via adaptee->method() — interface translation"
      },
      {
        "id": "std_function_wrapping",
        "shape_regex": "std::function\\s*<[^>]+>\\s*\\w+\\s*=\\s*(std::bind|std::mem_fn|\\[)",
        "weight": 0.5,
        "describe": "std::function wrapping a method via std::bind or lambda — functional-adapter signal"
      }
    ],
    "expected_collaborators": [
      {
        "id": "adaptee_referenced",
        "shape_regex": "\\b{class_name}\\s*\\(\\s*\\w+\\s*\\)",
        "weight": 0.4,
        "describe": "Adapter constructed with an adaptee argument"
      },
      {
        "id": "bind_adaptee_method",
        "shape_regex": "std::bind\\s*\\(\\s*&?\\w+::\\w+",
        "weight": 0.45,
        "describe": "std::bind used to bind an adaptee member function"
      },
      {
        "id": "interface_override",
        "shape_regex": "\\bvirtual\\s+\\w+[\\s\\S]{0,80}override\\b",
        "weight": 0.25,
        "describe": "Adapter overrides target interface methods"
      }
    ],
    "global_functions": [],
    "negative_signals": [
      {
        "id": "decorator_chain_giveaway",
        "shape_regex": "\\bnew\\s+\\w+\\s*\\(\\s*new\\s+\\w+",
        "weight": -0.4,
        "describe": "Nested constructors are a Decorator giveaway, not Adapter"
      }
    ]
  }
}
