{
  "pattern_id": "creational.factory",
  "pattern_family": "creational",
  "pattern_name": "Factory",
  "enabled": true,
  "signature_categories": [
    "object_instantiation"
  ],
  "lexeme_identifiers": {
    "object_instantiation":  ["make_unique", "make_shared", "std::make_unique", "std::make_shared",
                              "allocate_shared", "new", "unique_ptr", "shared_ptr",
                              "std::unique_ptr", "std::shared_ptr"],
    "return_value":          ["return"],
    "branch_decision":       ["if", "switch", "case"],
    "factory_method_names":  ["create", "make", "build", "produce", "newInstance", "manufacture",
                              "instantiate", "spawn", "generate", "construct", "createProduct",
                              "createObject", "makeObject", "buildProduct"],
    "product_ptr_types":     ["unique_ptr", "shared_ptr", "auto",
                              "std::unique_ptr", "std::shared_ptr"],
    "virtual_interface":     ["virtual", "override", "final", "= 0", "pure"]
  },
  "ordered_checks": [
    {
      "id": "class_introducer",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["class", "struct"]
    },
    {
      "id": "class_name",
      "expected_kind": "Identifier",
      "capture_as": "class_name",
      "document_as": "factory_class"
    },
    {
      "id": "open_class_brace",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["{"]
    },
    {
      "id": "branch_decision",
      "one_of": [
        { "expected_kind": "Keyword", "expected_lexeme_any_of": ["if"] },
        { "expected_kind": "Keyword", "expected_lexeme_any_of": ["switch"] }
      ],
      "document_as": "factory_branch_decision"
    },
    {
      "id": "concrete_construction",
      "one_of": [
        { "expected_kind": "Keyword",    "expected_lexeme_any_of": ["new"] },
        { "expected_kind": "Identifier", "expected_lexeme_any_of": ["make_unique", "make_shared",
                                                                     "std::make_unique", "std::make_shared",
                                                                     "allocate_shared"] }
      ],
      "document_as": "factory_concrete_creation"
    },
    {
      "id": "return_concrete",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["return"],
      "document_as": "factory_return"
    }
  ],

  "implementation_template": {
    "callsites": [
      {
        "id": "branch_return_construct",
        "shape_regex": "(if|switch|case)[\\s\\S]{0,200}return\\s+((std::)?make_(unique|shared)\\s*<|new\\s+\\w+)",
        "weight": 0.7,
        "describe": "Branched factory: type/string/enum decides which concrete to construct"
      },
      {
        "id": "factory_method_signature",
        "shape_regex": "\\b(static\\s+)?(std::)?(unique_ptr|shared_ptr)\\s*<[^>]+>\\s+(create|make|build|produce|newInstance|manufacture|instantiate)\\w*\\s*\\(",
        "weight": 0.65,
        "describe": "Method named create/make/build returning a smart pointer to a base type"
      },
      {
        "id": "polymorphic_return_type",
        "shape_regex": "(std::)?(unique_ptr|shared_ptr)\\s*<\\s*\\w+\\s*>\\s+\\w+\\s*\\([^)]*\\)\\s*(const\\s*)?\\{[\\s\\S]{0,300}return\\s+(std::)?make_",
        "weight": 0.5,
        "describe": "Function returns smart pointer to a base, body emits make_unique/shared"
      },
      {
        "id": "register_or_map_lookup",
        "shape_regex": "\\b(registry|factories|creators|builders|map_|m_map)\\b[\\s\\S]{0,80}\\.\\s*(at|find|operator\\[\\])",
        "weight": 0.4,
        "describe": "Registry-style factory using a map of creators"
      }
    ],
    "expected_collaborators": [
      {
        "id": "abstract_product_present",
        "shape_regex": "class\\s+\\w+\\s*\\{[\\s\\S]{0,400}virtual\\s+[^=;]+=\\s*0",
        "weight": 0.3,
        "describe": "An abstract product (pure virtual) is declared — typical for factories"
      }
    ],
    "global_functions": [],
    "negative_signals": [
      {
        "id": "no_construction",
        "shape_regex": "class\\s+{class_name}\\s*[:\\{][\\s\\S]{0,1200}\\}(?![\\s\\S]*\\b(new\\s+\\w+|make_unique|make_shared)\\b)",
        "weight": -0.5,
        "describe": "No `new`/make_* anywhere in the class — not a factory"
      }
    ]
  }
}
