{
  "pattern_id": "creational.builder",
  "pattern_family": "creational",
  "pattern_name": "Builder",
  "enabled": true,
  "signature_categories": [
    "self_return"
  ],
  "lexeme_identifiers": {
    "chain_return":      ["return", "*", "this", "&"],
    "setter_prefix":     ["set", "with", "add", "append", "configure", "enable",
                          "disable", "toggle", "reset", "assign", "attach", "put"],
    "terminator":        ["build", "Build", "create", "make", "construct",
                          "finalize", "done", "complete", "get", "produce", "assemble"],
    "ownership_output":  ["make_unique", "make_shared", "std::make_unique", "std::make_shared",
                          "unique_ptr", "shared_ptr", "std::unique_ptr", "std::shared_ptr",
                          "new"],
    "inner_state_types": ["std::string", "std::vector", "std::optional",
                          "std::map", "std::unordered_map", "optional", "vector"]
  },
  "ordered_checks": [
    {
      "id": "class_introducer",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["class", "struct"]
    },
    {
      "id": "class_name",
      "expected_kind": "Identifier",
      "capture_as": "class_name",
      "document_as": "builder_class"
    },
    {
      "id": "open_class_brace",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["{"]
    },
    {
      "id": "fluent_return_signature",
      "expected_kind": "Operator",
      "expected_lexeme_any_of": ["&"],
      "document_as": "fluent_setter_return"
    },
    {
      "id": "fluent_return_keyword",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["return"]
    },
    {
      "id": "fluent_return_this",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["this"],
      "document_as": "fluent_self_return"
    }
  ],

  "implementation_template": {
    "callsites": [
      {
        "id": "fluent_self_return",
        "shape_regex": "return\\s+\\*\\s*this\\s*;",
        "weight": 0.6,
        "describe": "Fluent setter returns *this — canonical builder chaining"
      },
      {
        "id": "fluent_setter_signature",
        "shape_regex": "{class_name}\\s*&\\s+(set|with|add|append|configure|enable|disable|attach|put)\\w*\\s*\\(",
        "weight": 0.5,
        "describe": "Setter returning Builder& — fluent interface signature"
      },
      {
        "id": "build_terminator_method",
        "shape_regex": "\\b(\\w+|(std::)?(unique_ptr|shared_ptr)\\s*<[^>]+>)\\s+(build|Build|finalize|done|complete|construct|produce|assemble)\\s*\\(\\s*\\)\\s*(const\\s*)?\\{",
        "weight": 0.55,
        "describe": "Terminator method named build/finalize/etc. that returns the product"
      },
      {
        "id": "chained_setter_usage",
        "shape_regex": "\\.\\s*(set|with|add|append|configure|enable|attach)\\w*\\s*\\([^)]*\\)\\s*\\.\\s*(set|with|add|append|configure|enable|attach|build|done)\\w*\\s*\\(",
        "weight": 0.55,
        "describe": "Caller chains two or more fluent setters in sequence"
      }
    ],
    "expected_collaborators": [
      {
        "id": "internal_state_member",
        "shape_regex": "\\b(std::)?(string|vector|optional|map|unordered_map)\\s*<?[^;]{0,80};",
        "weight": 0.2,
        "describe": "Builder accumulates state in collection-like members"
      }
    ],
    "global_functions": [],
    "negative_signals": [
      {
        "id": "no_terminator",
        "shape_regex": "class\\s+{class_name}\\s*[:\\{][\\s\\S]{0,1200}\\}(?![\\s\\S]*\\b(build|finalize|done|complete|produce|assemble)\\s*\\()",
        "weight": -0.4,
        "describe": "No terminator method found — likely not a Builder"
      }
    ]
  }
}
