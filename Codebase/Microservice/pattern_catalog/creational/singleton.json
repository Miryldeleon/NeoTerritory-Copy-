{
  "pattern_id": "creational.singleton",
  "pattern_family": "creational",
  "pattern_name": "Singleton",
  "enabled": true,
  "signature_categories": [
    "destruction_signal"
  ],
  "lexeme_identifiers": {
    "static_storage":   ["static"],
    "accessor":         ["instance", "getInstance", "get_instance", "GetInstance",
                         "sharedInstance", "getSharedInstance", "getDefault",
                         "get", "shared", "unique"],
    "deleted_ops":      ["delete", "="],
    "thread_safety":    ["mutex", "lock_guard", "unique_lock", "scoped_lock",
                         "call_once", "once_flag", "std::mutex", "std::lock_guard",
                         "std::once_flag", "std::call_once", "std::scoped_lock"],
    "local_static_init":["static", "inline"],
    "ownership_policy": ["unique_ptr", "shared_ptr", "std::unique_ptr",
                         "std::shared_ptr", "make_unique", "make_shared"]
  },
  "ordered_checks": [
    {
      "id": "class_introducer",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["class", "struct"]
    },
    {
      "id": "class_name",
      "expected_kind": "Identifier",
      "capture_as": "class_name",
      "document_as": "singleton_class"
    },
    {
      "id": "open_class_brace",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["{"]
    },
    {
      "id": "static_keyword",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["static"],
      "document_as": "static_instance_accessor"
    },
    {
      "id": "accessor_returns_reference",
      "expected_kind": "Operator",
      "expected_lexeme_any_of": ["&"]
    },
    {
      "id": "accessor_name",
      "expected_kind": "Identifier",
      "capture_as": "accessor_name",
      "document_as": "instance_accessor_method"
    },
    {
      "id": "accessor_open_paren",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": ["("]
    },
    {
      "id": "accessor_close_paren",
      "expected_kind": "Punctuation",
      "expected_lexeme_any_of": [")"]
    },
    {
      "id": "deleted_copy_op",
      "expected_kind": "Keyword",
      "expected_lexeme_any_of": ["delete"],
      "document_as": "explicit_copy_deletion",
      "optional": true
    }
  ],

  "implementation_template": {
    "callsites": [
      {
        "id": "static_instance_accessor",
        "shape_regex": "\\bstatic\\s+{class_name}\\s*[&*]?\\s*(getInstance|get_instance|GetInstance|instance|sharedInstance|getDefault)\\s*\\(\\s*\\)",
        "weight": 0.7,
        "describe": "static accessor returning the single instance"
      },
      {
        "id": "meyers_local_static",
        "shape_regex": "\\bstatic\\s+{class_name}\\s+\\w+\\s*;[\\s\\S]{0,80}return\\s+\\w+\\s*;",
        "weight": 0.65,
        "describe": "Meyers singleton: function-local `static T inst;` then return"
      },
      {
        "id": "deleted_copy_ctor",
        "shape_regex": "{class_name}\\s*\\(\\s*const\\s+{class_name}\\s*&\\s*\\)\\s*=\\s*delete",
        "weight": 0.45,
        "describe": "Copy constructor explicitly deleted"
      },
      {
        "id": "deleted_assignment",
        "shape_regex": "{class_name}\\s*&\\s*operator\\s*=\\s*\\(\\s*const\\s+{class_name}\\s*&\\s*\\)\\s*=\\s*delete",
        "weight": 0.35,
        "describe": "Copy assignment explicitly deleted"
      },
      {
        "id": "private_ctor",
        "shape_regex": "private\\s*:[\\s\\S]{0,200}{class_name}\\s*\\(\\s*\\)\\s*[;{=]",
        "weight": 0.4,
        "describe": "Constructor declared in private section"
      },
      {
        "id": "call_once_init",
        "shape_regex": "(std::)?call_once\\s*\\([\\s\\S]{0,200}(new\\s+{class_name}|make_unique\\s*<\\s*{class_name})",
        "weight": 0.55,
        "describe": "std::call_once protects single instance creation"
      }
    ],
    "expected_collaborators": [],
    "global_functions": [],
    "negative_signals": [
      {
        "id": "no_static_accessor",
        "shape_regex": "class\\s+{class_name}\\s*[:\\{][\\s\\S]{0,1200}\\}(?![\\s\\S]*\\bstatic\\b)",
        "weight": -0.5,
        "describe": "No static keyword anywhere in the class — not a singleton"
      }
    ]
  }
}
